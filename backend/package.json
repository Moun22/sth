{
  "name": "sth-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:mongo": "tsx src/scripts/seed-mongo.ts",
    "docker:up": "docker compose -f ../docker-compose.yml up -d",
    "docker:up:build": "docker compose -f ../docker-compose.yml up -d --build",
    "docker:up:fresh": "docker compose -f ../docker-compose.yml up -d --build --renew-anon-volumes",
    "docker:down": "docker compose -f ../docker-compose.yml down",
    "docker:logs": "docker compose -f ../docker-compose.yml logs -f api"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.15",
    "mongodb": "^7.2.0",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
